# Notion integration secret. Create one at https://www.notion.so/my-integrations
# then "Share" your database with that integration.
NOTION_TOKEN=secret_xxx

# The database id from your Notion URL (the part before `?v=`).
# For your space this is: 260687f2b6dd80fb9812f1c474d67592
NOTION_DATABASE_ID=260687f2b6dd80fb9812f1c474d67592

# Honouring the database's manual drag-sort order (e.g. nav menu grouping) needs
# the private API, which the official token can't reach. Recommended (NotionNext
# style): open your database in Notion → Share → "Publish to web". Then it's
# read without any credential below — no expiry, nothing to maintain.
#
# Only if you DON'T want the database publicly viewable: keep it private and
# supply your browser `token_v2` cookie instead (notion.so → DevTools →
# Application → Cookies → token_v2). This cookie expires and must be refreshed;
# never commit it. Leave both empty to fall back to the official query order.
NOTION_TOKEN_V2=
NOTION_ACTIVE_USER=
