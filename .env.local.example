# Notion integration secret. Create one at https://www.notion.so/my-integrations
# then "Share" your database with that integration.
NOTION_TOKEN=secret_xxx

# The database id from your Notion URL (the part before `?v=`).
# For your space this is: 260687f2b6dd80fb9812f1c474d67592
NOTION_DATABASE_ID=260687f2b6dd80fb9812f1c474d67592
